# ===== 光湖网站统一环境变量 =====
# GH-INT-001 三模块集成配置

# --- 前端 (Next.js :3000) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8765
NEXT_PUBLIC_SITE_NAME=光湖 · GuangHu Lab

# --- 后端API (FastAPI :8000) ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
API_CORS_ORIGINS=http://localhost:3000

# --- WebSocket (ws_server :8765) ---
WS_HOST=0.0.0.0
WS_PORT=8765

# --- 数据库 (PostgreSQL :5432) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=guanghu
DB_USER=guanghu
DB_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://guanghu:change-me-in-production@localhost:5432/guanghu

# --- Redis (可选, 消息队列) ---
REDIS_URL=redis://localhost:6379/0
