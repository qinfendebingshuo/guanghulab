# ============================================
# 晨星交互平台 · 环境变量配置
# 桔子妈妈填写说明：
# 1. 把这个文件复制一份，改名为 .env
# 2. 按照下面的说明填写每一项
# 3. 运行 python main.py 就行了
# ============================================

# ---------- DeepSeek API 配置 ----------
# 获取地址: https://platform.deepseek.com/
# 注册后在「API Keys」页面创建一个Key，复制粘贴到这里
DEEPSEEK_API_KEY=在这里粘贴你的DeepSeek API Key

# 模型选择:
#   deepseek-chat    = 普通聊天版（快·便宜）
#   deepseek-reasoner = 推理版（慢一点·会思考）
DEEPSEEK_MODEL=deepseek-chat

# API地址（一般不需要改）
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 最大回复长度（一般不需要改）
DEEPSEEK_MAX_TOKENS=2048

# 回复随机性（0.0=很确定 ~ 1.0=很随机，建议0.7）
DEEPSEEK_TEMPERATURE=0.7

# ---------- Notion API 配置（可选）----------
# 如果要从Notion同步世界观内容，需要填写
# 获取方法: 在Notion中创建一个Integration
# 教程: https://developers.notion.com/docs/create-a-notion-integration
NOTION_TOKEN=

# ---------- 数据库配置 ----------
# 数据库文件路径（一般不需要改，默认在当前目录下）
CHENXING_DB_PATH=chenxing.db

# ---------- 同步配置 ----------
# 从Notion同步世界观的间隔（小时）
SYNC_INTERVAL_HOURS=1

# ---------- 服务配置 ----------
# 服务端口（桔子妈妈的前端会连这个端口）
PORT=8000
