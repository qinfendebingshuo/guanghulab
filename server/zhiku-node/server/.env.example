# ═══════════════════════════════════════════════════════════
# 光湖智库节点 · 环境变量模板
# 项目编号: ZY-PROJ-006
# 域名:     guanghu.online
# 守护:     铸渊 · ICE-GL-ZY001
# 版权:     国作登字-2026-A-00037559
#
# 使用方法: cp .env.example .env 然后填入实际值
# 生产环境由 GitHub Actions 部署时自动写入
# ═══════════════════════════════════════════════════════════

# 服务端口（Nginx 反代到此端口）
PORT=3006

# 运行环境
NODE_ENV=production

# JWT 签名密钥（必须设置·生产环境缺失则拒绝启动）
ZY_ZHIKU_JWT_SECRET=

# 用户 Token 有效期（秒）· 默认 86400（24小时）
ZY_ZHIKU_TOKEN_TTL=86400

# ─── 腾讯云 COS 存储配置 ───
# 下载的小说 TXT 文件自动上传到 COS 存储桶
# GitHub Secrets 映射: ZY_OSS_KEY → ZY_COS_SECRET_ID, ZY_OSS_SECRET → ZY_COS_SECRET_KEY
ZY_COS_SECRET_ID=
ZY_COS_SECRET_KEY=
ZY_COS_BUCKET=
ZY_COS_REGION=ap-singapore

# 数据目录
ZY_ZHIKU_DATA_DIR=/opt/zhiku/data

# 日志目录
ZY_ZHIKU_LOG_DIR=/var/log/zhiku

# 域名
ZY_ZHIKU_DOMAIN=guanghu.online

# ─── 数据源 API 地址 ───
# FQWeb (番茄小说 Kotlin JAR 服务) · 由 setup-datasources 部署到本机
# 仓库: https://github.com/benefit77/FanQieWeb
ZY_FANQIE_API_URL=http://127.0.0.1:9999

# SwiftCat (七猫小说 Python 下载器) · 由 setup-datasources 部署到本机
# 仓库: https://github.com/shing-yu/swiftcat-downloader
ZY_QIMAO_API_URL=http://127.0.0.1:7700

# ─── LLM API 配置（DeepSeek · Agent对话）───
ZY_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
ZY_DEEPSEEK_API_KEY=

# ─── 邮件发送配置（SMTP 直发）───
ZY_SMTP_HOST=
ZY_SMTP_PORT=465
ZY_SMTP_USER=
ZY_SMTP_PASS=

# 主站 API 地址（用于邮件转发等）
ZY_MAIN_API_URL=http://127.0.0.1:3800
