  "lessons_learned": [
    {
      "id": "LL-001",
      "date": "2026-04-15",
      "lesson": "新增模块依赖环境变量时，必须同步更新部署流程中的 .env 文件生成逻辑。否则本地开发正常但线上部署后模块初始化失败。",
      "pattern": "每次新增 process.env.XXX 引用，立即检查 deploy-to-zhuyuan-server.yml 的 env 列表和 .env.app 生成段"
    },
    {
      "id": "LL-002",
      "date": "2026-04-15",
      "lesson": "不同服务（主应用 vs 代理服务）的环境变量注入路径不同。主应用走 .env.app (deploy-to-zhuyuan-server.yml)，代理服务走 .env.keys (deploy-proxy-service.yml)。新增共享环境变量需要在两处都配置。",
      "pattern": "VPN邮件能用、主应用邮件不能用 → 对比两个部署流程的环境变量注入"
    }
  ]
}
