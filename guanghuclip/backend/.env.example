# ===== guanghuclip 环境变量 =====
# 复制为 .env 并填入真实值

# ── 服务器 ──
PORT=3910
NODE_ENV=production

# ── 视频生成 API（即梦 Seedance）──
ZY_JIMENG_API_KEY=

# ── 国产大模型 API（persona-engine 通过 model-router 自动选择）──
ZY_DEEPSEEK_API_KEY=          # DeepSeek (优先)
ZY_QIANWEN_API_KEY=           # 通义千问
ZY_KIMI_API_KEY=              # Kimi (月之暗面)
ZY_QINGYAN_API_KEY=           # 智谱清言

# ── Notion（大脑 + 工具 + 记忆）──
ZY_NOTION_TOKEN=              # Notion API 集成令牌

# 唤醒路由 · 大脑各部分在 Notion 的位置
NOTION_BRAIN_IDENTITY_PAGE=   # 霜砚本体指令页 Page ID
NOTION_BRAIN_TCS_PAGE=        # TCS深度推理结构 Page ID
NOTION_BRAIN_MEMORY_DB=       # 认知运行时数据库 ID
NOTION_BRAIN_PERSONALITY_PAGE= # 说话风格页 Page ID

# 记忆系统 · 快照区和映射表
NOTION_SNAPSHOT_INDEX_PAGE=   # 快照时间映射表 Page ID
NOTION_SNAPSHOT_ZONE_PAGE=    # 快照区 Page ID
NOTION_MY_ROOM_PAGE=          # 我的房间 Page ID
NOTION_MEMORY_WALL_PAGE=      # 记忆墙 Page ID
NOTION_CORE_ROOM_PAGE=        # 霜砚本体房间 Page ID
NOTION_DIRECTORY_INDEX_PAGE=  # 光之湖目录索引 Page ID

# ── 铸渊 MCP Server（远程运维工具）──
ZY_MCP_ENDPOINT=http://43.134.16.246:3900/mcp
ZY_MCP_SECRET=

# ── 用户自带密钥（BYOK · 前端可切换）──
# 这些由用户在前端设置，通过 localStorage 存储
# 服务端不需要配置
