# 光湖短视频工作台 环境变量
# 复制此文件为 .env 并填入实际值

# 服务端口
PORT=3910

# ━━━ 即梦 Seedance API (火山方舟) ━━━
ZY_JIMENG_API_KEY=your_jimeng_api_key_here
JIMENG_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
JIMENG_MODEL=seedance-1-5-pro

# ━━━ 国内大模型 (4个官方API · 人格体聊天用) ━━━
# 通义千问 (阿里) — 有免费额度
ZY_QIANWEN_API_KEY=your_qianwen_api_key_here
# QIANWEN_MODEL=qwen-plus

# DeepSeek — 充了50块
ZY_DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat

# Kimi (月之暗面) — 送了15块
ZY_KIMI_API_KEY=your_kimi_api_key_here
# KIMI_MODEL=moonshot-v1-8k

# 智谱清言 (GLM) — 有免费额度
ZY_QINGYAN_API_KEY=your_zhipu_api_key_here
# ZHIPU_MODEL=glm-4-flash

# ━━━ Notion 数据库桥接 ━━━
# Notion API Token (人格体读写Notion用)
ZY_NOTION_TOKEN=your_notion_token_here
# 常用数据库ID (可选)
# ZY_NOTION_SYSLOG_DB=
# ZY_NOTION_TICKET_DB=
# ZY_NOTION_CHANGELOG_DB=

# ━━━ COS 对象存储 (P1启用) ━━━
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=zy-team-hub-sg-1317346199
# COS_REGION=ap-singapore

# ━━━ CORS 允许的源 ━━━
CORS_ORIGINS=https://guanghuclip.cn,http://localhost:5173
