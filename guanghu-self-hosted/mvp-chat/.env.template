# ==========================================
# 光湖 MVP Chat · 环境变量模板
# 复制为 .env 并填入实际值
# 工单: YD-A05-20260430-MVP
# ==========================================

# === 百炼模型API（必填）===
DASHSCOPE_API_KEY=           # 百炼API密钥（用户自己在阿里云申请）
SYSTEM_MODEL=shuangyan-system-v1  # 系统侧微调模型ID
NAIPPING_MODEL=naipping-v1        # 奶瓶侧微调模型ID

# === 深度推理（可选 · 不填则跳过）===
DEEPSEEK_API_KEY=            # DeepSeek API密钥
QWEN_API_KEY=                # 通义千问API密钥

# === Notion连接（必填）===
ZY_NOTION_TOKEN=             # 系统Notion Token（人格体大脑·冰朔的workspace）
USER_NOTION_TOKEN=           # 用户Notion Token（OAuth获取或手动填入）

# === PostgreSQL（必填）===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=guanghu
DB_USER=guanghu
DB_PASSWORD=                 # 数据库密码（必填）

# === 服务端口 ===
CHAT_PORT=3000               # 前端+编排层端口
API_PORT=8000                # 后端API端口
MEMORY_ROUTER_PORT=8001      # 记忆路由端口
