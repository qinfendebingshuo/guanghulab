# ============================================================
# 光湖网站 · 统一环境变量模板
# GH-INT-001 · 三模块集成(前端+API+聊天)
# ============================================================

# ==================== 前端 (Next.js) ====================
# Next.js 监听端口
PORT=3000

# API地址 (浏览器端)
# 开发环境: Next.js rewrites代理 → 无需设置
# 生产环境: 设置为后端API的完整URL
NEXT_PUBLIC_API_URL=/api

# WebSocket地址 (浏览器端直连聊天后端)
NEXT_PUBLIC_WS_URL=ws://localhost:8765/ws

# CORS允许的源
CORS_ORIGIN=http://localhost:3000

# ==================== 后端API (GH-API-001 · FastAPI) ====================
# API服务端口
API_PORT=8000

# API上游地址 (Next.js rewrites代理目标)
API_UPSTREAM_URL=http://localhost:8000

# 数据库连接 (PostgreSQL + pgvector)
DATABASE_URL=postgresql://guanghu:guanghu_dev@localhost:5432/guanghu_db

# ==================== 聊天WebSocket (GH-CHAT-001 · FastAPI) ====================
# WS服务监听地址
GH_CHAT_HOST=0.0.0.0
GH_CHAT_PORT=8765

# WS CORS允许的源(逗号分隔)
GH_CHAT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== 数据库 (GH-DB-001 · PostgreSQL) ====================
POSTGRES_USER=guanghu
POSTGRES_PASSWORD=guanghu_dev
POSTGRES_DB=guanghu_db
POSTGRES_PORT=5432

# ==================== 通用 ====================
NODE_ENV=development
LOG_LEVEL=info
